# Environment Variables — Local Development
# Vercel pe ye Vercel Dashboard > Settings > Environment Variables me dalna

# iThink Logistics API Credentials
# iThink Dashboard > Settings > API Keys se copy karo
ITHINK_ACCESS_TOKEN=your_ithink_access_token_here
ITHINK_SECRET_KEY=your_ithink_secret_key_here
ITHINK_WAREHOUSE_ID=your_warehouse_id_here

# EmailJS (optional, already in frontend)
# VITE_EMAILJS_PUBLIC_KEY=your_key_here
